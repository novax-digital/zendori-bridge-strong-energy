# ── Zendori v1 — environment reference (see CLAUDE.md §14) ─────────────────
# Copy to .env for local dev; set the same values in the Vercel project
# settings for deployments. Mailbox credentials live encrypted in the DB.

# App
NEXT_PUBLIC_APP_URL=https://strongenergy.zendori.ai

# Postgres (Supabase) — ONLY needed for running migrations via psql.
# Use the Supavisor session pooler (port 5432, username postgres.<project-ref>)
# or the direct connection. The app itself talks to Supabase via HTTPS.
DATABASE_URL=postgresql://postgres.<project-ref>:<password>@aws-<region>.pooler.supabase.com:5432/postgres

# Supabase (project: EU region, e.g. eu-central-1)
SUPABASE_URL=https://<project-ref>.supabase.co
# Publishable key (browser-safe; new sb_publishable_... key or legacy anon key)
SUPABASE_ANON_KEY=sb_publishable_...
# Secret key (server ONLY, bypasses RLS; new sb_secret_... key or legacy service_role key)
SUPABASE_SERVICE_ROLE_KEY=sb_secret_...
# Next.js requires the NEXT_PUBLIC_ prefix for values used in the web app —
# same values as SUPABASE_URL / SUPABASE_ANON_KEY above:
NEXT_PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_...

# Vercel Cron auth — Vercel sends "Authorization: Bearer <CRON_SECRET>" to cron
# endpoints. Generate: node -e "console.log(require('crypto').randomBytes(24).toString('hex'))"
CRON_SECRET=

# Anthropic (models overridable; escalation model must NOT receive temperature)
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL_EXTRACT=claude-haiku-4-5
ANTHROPIC_MODEL_ESCALATION=claude-sonnet-5

# HubSpot (private app of the client)
HUBSPOT_TOKEN=pat-eu1-...
HUBSPOT_PIPELINE_ID=
HUBSPOT_STAGE_ID=

# Crypto — 32-byte key, hex-encoded (64 hex chars). Generate:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=

# Twilio (Phase 2)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=

# Vapi (Phase 2)
VAPI_API_KEY=
VAPI_WEBHOOK_SECRET=

# Alerts
ADMIN_ALERT_EMAIL=
